  "item": [
    {
      "name": "01 - Multi-User Flow Tests",
      "item": [
        {
          "name": "Create Test User 1",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user1@watchparty.dev\",\n    \"password\": \"password123\",\n    \"confirm_password\": \"password123\",\n    \"first_name\": \"User\",\n    \"last_name\": \"One\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/auth/register/",
              "host": ["{{api_url}}"],
              "path": ["auth", "register", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('User 1 registration successful', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "if (pm.response.json() && pm.response.json().access_token) {",
                  "    pm.collectionVariables.set('user1_token', pm.response.json().access_token);",
                  "    pm.collectionVariables.set('user1_id', pm.response.json().user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Test User 2",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
