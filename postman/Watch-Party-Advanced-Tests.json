                  "    pm.expect(responseJson.success).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "User 2 Sends Chat Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user2_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
