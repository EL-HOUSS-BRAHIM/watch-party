    {
      "name": "07 - Security Tests",
      "item": [
        {
          "name": "SQL Injection Test - Search",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user1_token}}"
              }
            ],
            "url": {
              "raw": "{{api_url}}/videos/search/?q=' OR 1=1 --",
              "host": ["{{api_url}}"],
              "path": ["videos", "search", ""],
              "query": [
                {
                  "key": "q",
                  "value": "' OR 1=1 --"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('SQL injection attempt handled safely', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
                  "});",
                  "",
                  "pm.test('No error messages reveal database structure', function () {",
                  "    const responseText = pm.response.text();",
                  "    pm.expect(responseText).to.not.include('ORA-');",
                  "    pm.expect(responseText).to.not.include('SQL');",
                  "    pm.expect(responseText).to.not.include('mysql');",
                  "    pm.expect(responseText).to.not.include('postgresql');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "XSS Test - User Input",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user1_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"first_name\": \"<script>alert('XSS')</script>\",\n    \"last_name\": \"Test\",\n    \"bio\": \"<img src=x onerror=alert('XSS')>\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/users/profile/",
              "host": ["{{api_url}}"],
              "path": ["users", "profile", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('XSS attempt handled safely', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
                  "});",
                  "",
                  "pm.test('Script tags are sanitized or rejected', function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (pm.response.code === 200 && responseJson.first_name) {",
                  "        pm.expect(responseJson.first_name).to.not.include('<script>');",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Access Control Test - Other User's Party",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user2_token}}"
              }
            ],
            "url": {
              "raw": "{{api_url}}/parties/{{multi_user_party_id}}/",
              "host": ["{{api_url}}"],
              "path": ["parties", "{{multi_user_party_id}}", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Unauthorized deletion properly blocked', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403, 404]);",
                  "});",
                  "",
                  "pm.test('Error message indicates insufficient permissions', function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.detail) {",
                  "        pm.expect(responseJson.detail.toLowerCase()).to.include.oneOf(['permission', 'not found', 'forbidden']);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
