                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Multi-User Test Party\",\n    \"description\": \"Testing multi-user functionality\",\n    \"is_public\": true,\n    \"max_participants\": 5\n}"
            },
            "url": {
              "raw": "{{api_url}}/parties/",
              "host": ["{{api_url}}"],
              "path": ["parties", ""]
