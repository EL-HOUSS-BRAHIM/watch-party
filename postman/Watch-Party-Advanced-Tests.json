            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"message\": \"Hello from User 2!\",\n    \"message_type\": \"text\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/chat/{{multi_user_party_id}}/messages/send/",
              "host": ["{{api_url}}"],
              "path": ["chat", "{{multi_user_party_id}}", "messages", "send", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('User 2 message sent', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Message content correct', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.message).to.eql('Hello from User 2!');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "User 1 Reads Chat Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user1_token}}"
              }
            ],
            "url": {
              "raw": "{{api_url}}/chat/{{multi_user_party_id}}/messages/",
              "host": ["{{api_url}}"],
              "path": ["chat", "{{multi_user_party_id}}", "messages", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('User 1 can read messages', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('User 2 message is visible', function () {",
                  "    const responseJson = pm.response.json();",
                  "    const messages = responseJson.results || responseJson;",
                  "    const user2Message = messages.find(msg => msg.message === 'Hello from User 2!');",
                  "    pm.expect(user2Message).to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
