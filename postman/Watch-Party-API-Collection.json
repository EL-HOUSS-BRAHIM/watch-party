                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"{{test_password}}\",\n    \"confirm_password\": \"{{test_password}}\",\n    \"first_name\": \"Test\",\n    \"last_name\": \"User\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/auth/register/",
              "host": ["{{api_url}}"],
              "path": ["auth", "register", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Registration successful', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Registration returns tokens', function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (pm.response.code === 201) {",
                  "        pm.expect(responseJson).to.have.property('access_token');",
                  "        pm.expect(responseJson).to.have.property('refresh_token');",
                  "        pm.expect(responseJson).to.have.property('user');",
                  "    }",
                  "});",
