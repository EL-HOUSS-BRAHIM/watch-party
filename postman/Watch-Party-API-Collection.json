      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-refresh token if needed",
          "const accessToken = pm.collectionVariables.get('access_token');",
          "const refreshToken = pm.collectionVariables.get('refresh_token');",
          "",
          "if (!accessToken && refreshToken) {",
          "    console.log('Access token missing, attempting refresh...');",
          "    // Will be handled by individual requests",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test scripts",
          "pm.test('Response time is less than 5000ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "",
          "pm.test('Response has Content-Type header', function () {",
          "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "});",
          "",
          "// Extract tokens from auth responses",
          "if (pm.response.json() && pm.response.json().access_token) {",
          "    pm.collectionVariables.set('access_token', pm.response.json().access_token);",
          "}",
          "",
          "if (pm.response.json() && pm.response.json().refresh_token) {",
          "    pm.collectionVariables.set('refresh_token', pm.response.json().refresh_token);",
          "}",
          "",
          "// Extract user ID from responses",
          "if (pm.response.json() && pm.response.json().user && pm.response.json().user.id) {",
          "    pm.collectionVariables.set('user_id', pm.response.json().user.id);",
          "}"
        ]
      }
    }
  ],
